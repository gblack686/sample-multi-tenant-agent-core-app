{
  "name": "eagle-excalidraw-mcp-app",
  "version": "1.0.0",
  "type": "module",
  "description": "Excalidraw MCP App — interactive diagram canvas for EAGLE admin chat",
  "private": true,
  "scripts": {
    "build": "cross-env INPUT=mcp-app.html vite build",
    "serve": "tsx server.ts",
    "dev": "concurrently \"cross-env INPUT=mcp-app.html vite build --watch\" \"tsx --watch server.ts\""
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.6",
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
